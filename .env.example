# Kingdom Scaling Principles — Environment Variables
#
# Copy this file to .env.local for local development.
# In production: set these in Vercel → Project → Settings → Environment Variables.
# NEVER commit .env.local or any file with real values.

# ───── STRIPE ─────
# From Stripe Dashboard → Developers → API keys
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx

# From Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# From Stripe Dashboard → Product catalog → (the $29 product) → Pricing → Price ID
STRIPE_PRICE_ID=price_xxx

# ───── GO HIGH LEVEL ─────
# Inbound Webhook URL generated by the workflow trigger in GHL
# Sub-account → Automation → Workflows → (your workflow) → Inbound Webhook trigger → copy URL
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/xxx

# ───── AD PIXELS (public — OK to expose in frontend) ─────
# Meta: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=

# Google Ads: AW-XXXXXXXXX/XXXXXXXXX
NEXT_PUBLIC_GOOGLE_CONVERSION_ID=

# TikTok: https://ads.tiktok.com → Assets → Events
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ───── DASHBOARD AUTH ─────
# Any string — this is the password for /dashboard (HTTP Basic Auth, username "ksp")
DASHBOARD_PASSWORD=change-me-please

# ───── VERCEL KV (analytics store) ─────
# Auto-populated by Vercel when you enable KV on the project.
# Don't set these manually in local dev unless you're testing against prod KV.
KV_REST_API_URL=
KV_REST_API_TOKEN=
